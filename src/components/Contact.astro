---

<section id="contact" class="contact" aria-labelledby="contact-heading">
  <div class="wrap contact-inner">
    <div class="contact-info">
      <p class="eyebrow">Get in touch</p>
      <h2 id="contact-heading">Discuss your project</h2>
      <p class="section-lede">
        Tell us a little about the job and we&rsquo;ll come back to you. For anything urgent,
        please call.
      </p>

      <ul class="contact-list" role="list">
        <li>
          <span class="contact-label">Phone</span>
          <a href="tel:+447966190511">07966 190511</a>
        </li>
        <li>
          <span class="contact-label">Email</span>
          <a href="mailto:nhformwork@gmail.com">nhformwork@gmail.com</a>
        </li>
        <li>
          <span class="contact-label">Service area</span>
          <span>Bath and surrounding areas, South West England</span>
        </li>
        <li>
          <span class="contact-label">Facebook</span>
          <a
            href="https://www.facebook.com/nhformwork/photos"
            rel="noopener"
            target="_blank"
            aria-label="NH Formwork on Facebook (opens in new tab)"
          >facebook.com/nhformwork/photos</a>
        </li>
      </ul>
    </div>

    <form
      class="contact-form"
      action="mailto:nhformwork@gmail.com"
      method="post"
      enctype="text/plain"
      aria-label="Contact NH Formwork"
    >
      <div class="field">
        <label for="f-name">Your name</label>
        <input id="f-name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="field">
        <label for="f-email">Email</label>
        <input id="f-email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="field">
        <label for="f-phone">Phone <span class="optional">(optional)</span></label>
        <input id="f-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" />
      </div>
      <div class="field">
        <label for="f-message">About the project</label>
        <textarea id="f-message" name="message" rows="5" required></textarea>
      </div>
      <button class="btn btn-primary" type="submit">Send enquiry</button>
      <p class="form-note small muted">
        Submitting opens your email app with the message ready to send.
      </p>
    </form>
  </div>
</section>
